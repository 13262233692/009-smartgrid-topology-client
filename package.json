{
  "name": "smartgrid-topology-client",
  "version": "1.0.0",
  "description": "IEC 61850 Substation GOOSE/SV Diagnostic Tool",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.node.json && vite build",
    "start": "electron dist/electron/main.js",
    "dev:electron": "npm run build:electron && electron .",
    "build:rust": "cd rust-core && cargo build --release",
    "build:all": "npm run build:rust && npm run build:electron",
    "sim": "cd rust-core && cargo run -- --mode simulate"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
